aws_region     = "ap-southeast-2"
project_name   = "multi-container-service"
instance_type  = "t3.micro"
ami_id         = ""  # REQUIRED: Ubuntu 22.04 LTS AMI ID for ap-southeast-2
key_pair_name  = ""  # REQUIRED: Name of your EC2 key pair (create at EC2 → Key Pairs)
my_ip          = "0.0.0.0/0"  # Replace with your IP for tighter security
subnet_id      = ""  # REQUIRED: Public subnet ID for your region (find in AWS EC2 → Subnets)
